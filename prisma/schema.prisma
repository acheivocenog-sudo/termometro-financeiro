generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  incomes          Income[]
  fixedExpenses    FixedExpense[]
  variableExpenses VariableExpense[]
  installments     Installment[]
  balance          Balance?
}

// Saldo atual (um por usuário, atualizado manualmente)
model Balance {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  updatedAt DateTime @updatedAt
}

// Receitas (salário, freelance, etc.)
model Income {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

// Despesas fixas (aluguel, internet, academia)
model FixedExpense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(12, 2)
  dueDay      Int      // dia do mês (1-31)
  recurring   Boolean  @default(true)
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Empréstimos e parcelas
model Installment {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description         String
  amount              Decimal  @db.Decimal(12, 2) // valor de cada parcela
  totalInstallments   Int      // total de parcelas
  remainingInstallments Int    // parcelas restantes
  dueDay              Int      // dia do mês que vence
  startDate           DateTime // data da primeira parcela
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

// Despesas variáveis (gastos do dia a dia)
model VariableExpense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  category    String   @default("Outros")
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}
