# =============================================================================
# Achei Você no Google Automação — Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA commite o arquivo ".env" com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL via docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/achei_voce_no_google?schema=public"

# -----------------------------------------------------------------------------
# NextAuth (autenticação do administrador)
# Gere um segredo com: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="coloque-um-segredo-aleatorio-aqui"

# -----------------------------------------------------------------------------
# Modo Mock — controla TODAS as integrações externas
# Deixe "true" enquanto não tiver as credenciais reais aprovadas.
# Com "true", os serviços abaixo retornam dados simulados (não fazem
# chamadas reais) e o fluxo completo do sistema pode ser testado.
# -----------------------------------------------------------------------------
USE_MOCK_APIS="true"

# -----------------------------------------------------------------------------
# Google Business Profile API (Perfil da Empresa no Google)
# Requer projeto no Google Cloud Console + OAuth2 + acesso aprovado à
# "Google Business Profile API" (aprovação manual da Google, pode levar dias).
# Veja o passo a passo no README.md.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Refresh token obtido após o fluxo OAuth2 (escopo business.manage)
GOOGLE_REFRESH_TOKEN=""

# -----------------------------------------------------------------------------
# WhatsApp Business Cloud API (Meta)
# Requer conta Meta Business + número de teste/produção aprovado.
# Veja o passo a passo no README.md.
# -----------------------------------------------------------------------------
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# -----------------------------------------------------------------------------
# E-mail (Resend)
# Crie uma conta em https://resend.com e gere uma API key.
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Achei Você no Google <relatorios@seudominio.com>"

# -----------------------------------------------------------------------------
# IA - Google Gemini
# Crie uma chave em https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
